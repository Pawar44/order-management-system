generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Store {
  id        String   @id @default(uuid())
  name      String
  orders    Order[]
  createdAt DateTime @default(now())
}

model Order {
  id           String      @id @default(uuid())
  storeId      String
  store        Store       @relation(fields: [storeId], references: [id])
  items        OrderItem[]
  totalAmount  Float
  status       OrderStatus @default(PLACED)
  createdAt    DateTime    @default(now())

  @@index([storeId])
  @@index([createdAt])
}

model OrderItem {
  id       String @id @default(uuid())
  orderId  String
  order    Order  @relation(fields: [orderId], references: [id])
  itemId   String
  itemName String
  qty      Int
  price    Float
}

// Archive table — same shape as Order, but stores items as JSON
// since archived orders are read-only history, no need for a live relation.
model OrderArchive {
  id          String      @id @default(uuid())
  originalId  String      @unique
  storeId     String
  items       Json
  totalAmount Float
  status      OrderStatus
  createdAt   DateTime
  archivedAt  DateTime    @default(now())

  @@index([storeId])
  @@index([createdAt])
}

enum OrderStatus {
  PLACED
  PREPARING
  COMPLETED
}